{
	"name": "kyudo-dojo-hub",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "npx playwright test",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@playwright/test": "^1.61.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.10",
		"oxlint": "^1.72.0",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.4.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.81.0",
		"react-router": "^7.17.0",
		"recharts": "^3.9.2",
		"zod": "^4.4.3"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
