{
	"name": "kyudo-dojo-hub",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "npx playwright test",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build",
		"preview": "vite preview"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@playwright/test": "^1.48.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.0",
		"@vitest/coverage-v8": "^2.1.0",
		"oxlint": "^0.12.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vitest": "^2.1.0"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.72.0",
		"react-router": "^7.13.2",
		"recharts": "^3.8.1",
		"zod": "^4.3.6"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
