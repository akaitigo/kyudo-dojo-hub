# =============================================================================
# kyudo-dojo-hub Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Go API Backend
# ---------------------------------------------------------------------------

# PostgreSQL connection string (required for Go API)
DATABASE_URL=postgres://kyudo:password@localhost:5432/kyudo_dojo_hub?sslmode=disable

# Server port (default: 8080)
PORT=8080

# Allowed CORS origin (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------

# API base URL — set to enable the real Go backend.
# When empty/unset, the frontend uses the in-memory mock API.
# Example: http://localhost:8080
VITE_API_BASE_URL=
